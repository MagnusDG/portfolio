---
import Page from '../layouts/Page.astro';
---

<Page
  title="Contact"
  description="Get in touch about technical writing, documentation, or content projects."
>
  <div class="page-wrap contact-page">

    <header class="page-header">
      <p class="section-label mono-label">Contact</p>
      <h1 class="page-heading">Get in touch</h1>
    </header>

    <div class="contact-body">
      <p class="contact-lead">
        I take on technical writing and documentation projects for dev tools, AI, and security products. If the work fits, reply rate is fast.
      </p>

      <div class="contact-options">
        <div class="contact-item">
          <p class="mono-label contact-label">Email</p>
          <a href="mailto:[NEEDS:email]" class="contact-value">[NEEDS: email]</a>
        </div>
        <div class="contact-item">
          <p class="mono-label contact-label">LinkedIn</p>
          <a
            href="https://www.linkedin.com/in/[NEEDS:linkedin-handle]"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value"
          >
            linkedin.com/in/[NEEDS: handle]
          </a>
        </div>
        <div class="contact-item">
          <p class="mono-label contact-label">Upwork</p>
          <a
            href="[NEEDS: upwork profile URL]"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value"
          >
            Upwork profile
          </a>
        </div>
      </div>

      <p class="contact-note">
        Not taking on every project. The ones I do take have a real technical problem to explain and a reader who will notice if the details are wrong.
      </p>
    </div>

  </div>
</Page>

<style>
  .contact-page {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: var(--gap-2xl);
  }

  .page-header {
    margin-bottom: var(--gap-xl);
  }

  .section-label { margin-bottom: var(--gap-sm); }

  .page-heading {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .contact-lead {
    font-size: var(--text-xl);
    color: var(--color-ink-2);
    line-height: var(--leading-normal);
    max-width: 540px;
    margin-bottom: var(--gap-xl);
  }

  .contact-options {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
    margin-bottom: var(--gap-xl);
    max-width: 480px;
  }

  .contact-label {
    color: var(--color-muted);
    margin-bottom: var(--gap-xs);
  }

  .contact-value {
    font-size: var(--text-lg);
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .contact-value:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .contact-note {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: var(--leading-normal);
    max-width: 480px;
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--color-rule);
  }
</style>
