---
import Page from '../../layouts/Page.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const enPosts = sortedPosts.filter(p => p.data.lang === 'en');
const viPosts = sortedPosts.filter(p => p.data.lang === 'vi');
---

<Page
  title="Writing"
  description="Technical explainers, analytical essays, and notes on documentation, AI, and security."
>
  <section class="page-wrap writing-index">

    <header class="page-header">
      <p class="section-label mono-label">Writing</p>
      <h1 class="page-heading">Posts</h1>
      <p class="page-sub">
        Technical explainers, analytical essays, and notes. English posts are indexed here. Vietnamese essays are listed separately below.
      </p>
    </header>

    <div class="posts-section">
      <div class="posts-list">
        {enPosts.map(entry => (
          <PostCard
            title={entry.data.title}
            description={entry.data.description}
            pubDate={entry.data.pubDate}
            category={entry.data.category}
            lang={entry.data.lang}
            slug={entry.slug}
          />
        ))}
        {enPosts.length === 0 && (
          <p class="empty mono-label">No posts yet.</p>
        )}
      </div>
    </div>

    {viPosts.length > 0 && (
      <div class="vi-section">
        <h2 class="vi-heading">
          <span class="mono-label">Essays (VI)</span>
          <span class="vi-sub">Bài viết tiếng Việt</span>
        </h2>
        <div class="posts-list">
          {viPosts.map(entry => (
            <PostCard
              title={entry.data.title}
              description={entry.data.description}
              pubDate={entry.data.pubDate}
              category={entry.data.category}
              lang={entry.data.lang}
              slug={entry.slug}
            />
          ))}
        </div>
      </div>
    )}

  </section>
</Page>

<style>
  .writing-index {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: var(--gap-2xl);
  }

  .page-header {
    max-width: 640px;
    margin-bottom: var(--gap-xl);
  }

  .section-label { margin-bottom: var(--gap-sm); }

  .page-heading {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin-bottom: var(--gap-md);
  }

  .page-sub {
    font-size: var(--text-lg);
    color: var(--color-ink-2);
    line-height: var(--leading-normal);
  }

  .posts-list {
    max-width: 720px;
  }

  .empty {
    color: var(--color-muted);
    padding-block: var(--gap-lg);
  }

  .vi-section {
    margin-top: var(--gap-2xl);
    padding-top: var(--gap-xl);
    border-top: 1px solid var(--color-rule);
  }

  .vi-heading {
    display: flex;
    align-items: baseline;
    gap: var(--gap-md);
    margin-bottom: var(--gap-lg);
  }

  .vi-sub {
    font-size: var(--text-base);
    color: var(--color-muted);
    font-weight: 400;
  }
</style>
